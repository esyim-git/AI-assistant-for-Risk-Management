<Window x:Class="RiskManagementAI.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RiskManagementAI.App.Controls"
        Title="Risk Management AI Assistant" Height="720" Width="1180" MinHeight="720" MinWidth="1180"
        ResizeMode="CanResize" SizeToContent="Manual">
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" MinWidth="480" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="SafetyPanelColumn" Width="340" MinWidth="280" MaxWidth="560" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="4" Background="#102033" Padding="16">
            <DockPanel>
                <TextBlock Text="Risk Management AI Assistant" Foreground="White" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="EnvironmentText" Text="Offline Mode / Local Model: Not Configured" Foreground="#B8D7FF" FontSize="13" HorizontalAlignment="Right" DockPanel.Dock="Right" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#F4F6F8" Padding="12">
            <StackPanel>
                <TextBlock Text="Menu" FontWeight="Bold" Margin="0,0,0,12" />
                <Button Content="Dashboard" Margin="0,4" Click="OnShowDashboard" />
                <Button Content="SQL Assistant" Margin="0,4" Click="OnNavigateSql" />
                <Button Content="VBA Assistant" Margin="0,4" Click="OnNavigateVba" />
                <Button Content="Data Analyzer" Margin="0,4" Click="OnNavigateData" />
                <Button Content="Risk Dashboard" Margin="0,4" Click="OnNavigateRiskDashboard" />
                <Button Content="Excel Report" Margin="0,4" Click="OnNavigateReport" />
                <Button Content="Regulation / NCR" Margin="0,4" Click="OnNavigateRegulation" />
                <Button Content="Feedback Center" Margin="0,4" Click="OnNavigateFeedback" />
                <Button Content="History" Margin="0,4" Click="OnShowHistory" />
                <Button Content="Settings" Margin="0,4" Click="OnShowSettings" />
            </StackPanel>
        </Border>

        <Grid x:Name="WorkspaceGrid" Grid.Row="1" Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="EditorRow" Height="2*" MinHeight="260" />
                <RowDefinition Height="8" />
                <RowDefinition x:Name="ResultRow" Height="*" MinHeight="180" />
            </Grid.RowDefinitions>

            <GridSplitter x:Name="EditorResultSplitter" Grid.Row="1"
                          Height="8"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                          Background="#E2E8F0" />

            <TabControl x:Name="MainTabs" Grid.Row="0">
                <TabItem x:Name="DashboardTab" Header="Dashboard">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="DashboardSummaryText" Text="Dashboard snapshot을 읽기 전입니다." Foreground="#475569" />
                        <DataGrid x:Name="DashboardGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Margin="0,8,0,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Metric" Binding="{Binding Metric}" Width="150" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="160" />
                                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="330" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Grid.Row="2" Content="상태 새로고침" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnRefreshDashboard" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="SqlTab" Header="SQL">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="SqlRequestBox" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="14"
                                 Text="SELECT TRADE_ID, BASE_DT FROM RISK_EXPOSURE_DAILY WHERE BASE_DT = :BASE_DT" />
                        <Button Grid.Row="1" Content="SQL 검사" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnCheckSql" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="DraftTab" Header="Draft">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="DraftRequestBox" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="14"
                                 Text="리스크 한도 점검용 조회 SQL 초안을 작성" />
                        <TextBox x:Name="DraftResultBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="14" Margin="0,8,0,0"
                                 Text="NoModelMode 결과가 여기에 표시됩니다." IsReadOnly="True" />
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="SQL 초안" Width="110" Click="OnGenerateSqlDraft" />
                            <Button Content="VBA 초안" Width="110" Margin="8,0,0,0" Click="OnGenerateVbaDraft" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem x:Name="VbaTab" Header="VBA">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="VbaRequestBox" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="14"
                                 Text="Option Explicit&#x0a;Sub SampleCheck()&#x0a;    MsgBox &quot;Review only&quot;&#x0a;End Sub" />
                        <Button Grid.Row="1" Content="VBA 검사" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnCheckVba" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="ExcelTab" Header="Excel">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" MinWidth="360" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="2*" MinWidth="300" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ExcelRequestBox" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                                     HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="14"
                                     Text="=XLOOKUP(A2,LimitTable[Desk],LimitTable[Limit])" />
                            <GridSplitter Grid.Column="1"
                                          Width="8"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                                          Background="#E2E8F0" />
                            <Border Grid.Column="2" BorderBrush="#CBD5E1" BorderThickness="1" Padding="8" Background="#FFFFFF">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="118" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="36" />
                                    </Grid.RowDefinitions>
                                    <DockPanel>
                                        <Button Content="검색" Width="64" DockPanel.Dock="Right" Margin="8,0,0,0" Click="OnSearchExcelFunctionHelper" />
                                        <TextBox x:Name="ExcelFunctionHelperQueryBox" Text="XLOOKUP" />
                                    </DockPanel>
                                    <ListBox x:Name="ExcelFunctionHelperList"
                                             Grid.Row="1"
                                             DisplayMemberPath="Name"
                                             SelectionChanged="OnExcelFunctionHelperSelectionChanged"
                                             Margin="0,8,0,0" />
                                    <TextBox x:Name="ExcelFunctionHelperDetailBox"
                                             Grid.Row="2"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Margin="0,8,0,0"
                                             Text="Excel 2021 함수 Helper를 검색하세요."
                                             IsReadOnly="True" />
                                    <Button x:Name="InsertExcelFunctionExampleButton"
                                            Grid.Row="3"
                                            Content="예시 수식 삽입"
                                            Width="120"
                                            HorizontalAlignment="Left"
                                            Margin="0,10,0,0"
                                            Click="OnInsertExcelFunctionExample" />
                                </Grid>
                            </Border>
                        </Grid>
                        <Button Grid.Row="1" Content="Excel 검사" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnCheckExcel" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="DataTab" Header="Data">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="DataPathBox" Text="samples/dummy_data/risk_exposure_sample.csv" />
                        <TextBox x:Name="DataPreviewBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0"
                                 Text="CSV 프로파일 결과가 여기에 표시됩니다." IsReadOnly="True" />
                        <Button Grid.Row="2" Content="CSV 분석" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnProfileData" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="RiskDashboardTab" Header="Risk">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="34" />
                            <RowDefinition Height="72" />
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="노출 CSV" VerticalAlignment="Center" />
                            <TextBox x:Name="RiskExposurePathBox" Grid.Column="1" Text="samples/dummy_data/risk_exposure_sample.csv" />
                            <TextBlock Grid.Column="2" Text="한도 CSV" Margin="10,0,0,0" VerticalAlignment="Center" />
                            <TextBox x:Name="RiskLimitPathBox" Grid.Column="3" Text="samples/dummy_data/risk_limit_sample.csv" />
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="BASE_DT" VerticalAlignment="Center" />
                            <TextBox x:Name="RiskBaseDateBox" Grid.Column="1" Text="20260617" />
                            <TextBlock Grid.Column="2" Text="Review-only · 동일 기준일 조인 · ABS 사용률" Margin="12,0,0,0" Foreground="#475569" VerticalAlignment="Center" />
                        </Grid>
                        <TextBox x:Name="RiskCommentRequestBox" Grid.Row="2" TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True"
                                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="14" Margin="0,8,0,0"
                                 Text="한도 초과 항목 후속 점검 필요" />
                        <TextBlock x:Name="RiskDashboardSummaryText" Grid.Row="3" Text="한도 모니터링 실행 전입니다." Foreground="#475569" Margin="0,8,0,0" />
                        <Grid Grid.Row="4" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" MinWidth="300" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="2*" MinWidth="220" />
                            </Grid.ColumnDefinitions>
                            <DataGrid x:Name="RiskLimitGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="BREACH">
                                                <Setter Property="Background" Value="#FEF2F2" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="WARNING">
                                                <Setter Property="Background" Value="#FFFBEB" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="BASE_DT" Binding="{Binding BaseDate}" Width="80" />
                                    <DataGridTextColumn Header="Portfolio" Binding="{Binding PortfolioId}" Width="110" />
                                    <DataGridTextColumn Header="Risk Factor" Binding="{Binding RiskFactor}" Width="130" />
                                    <DataGridTextColumn Header="Exposure" Binding="{Binding ExposureAmount, StringFormat=N0}" Width="110" />
                                    <DataGridTextColumn Header="Limit" Binding="{Binding LimitAmount, StringFormat=N0}" Width="110" />
                                    <DataGridTextColumn Header="Usage" Binding="{Binding UsagePercent}" Width="80" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="220" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Grid.Column="2" BorderBrush="#CBD5E1" BorderThickness="1" Padding="8" Background="#FFFFFF">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="24" />
                                        <RowDefinition Height="*" MinHeight="360" />
                                        <RowDefinition Height="48" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Risk Visual" FontWeight="SemiBold" Foreground="#334155" />
                                    <Canvas x:Name="RiskVisualCanvas" Grid.Row="1" MinHeight="360" Background="#F8FAFC" ClipToBounds="True" />
                                    <TextBlock x:Name="RiskVisualNoteText" Grid.Row="2" Text="시각화 실행 전입니다." TextWrapping="Wrap" Foreground="#475569" Margin="0,8,0,0" />
                                </Grid>
                            </Border>
                        </Grid>
                        <Button Grid.Row="5" Content="한도 점검" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnRunLimitMonitor" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="ReportTab" Header="Report">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="ReportNameBox" Text="risk_report_smoke" />
                        <TextBox x:Name="ReportResultBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0"
                                 Text="Excel 리포트 생성 결과가 여기에 표시됩니다." IsReadOnly="True" />
                        <Button Grid.Row="2" Content="리포트 생성" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnGenerateExcelReport" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="RegulationTab" Header="Regulation">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="KbQueryBox" Text="NCR" />
                        <TextBox x:Name="KbResultBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0"
                                 Text="공개 catalog 검색 결과가 여기에 표시됩니다." IsReadOnly="True" />
                        <Button Grid.Row="2" Content="Catalog 검색" Width="120" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnSearchKbCatalog" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="FeedbackTab" Header="Feedback">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="34" />
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="FeedbackIdBox" Text="feedback-ui-001" />
                        <TextBox x:Name="FeedbackTaskIdBox" Grid.Row="1" Text="task-ui-001" Margin="0,6,0,0" />
                        <Grid Grid.Row="2" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FeedbackCodeBox" Text="APPROVED" />
                            <TextBox x:Name="FeedbackReviewStatusBox" Grid.Column="1" Text="ReviewerApproved" Margin="8,0,0,0" />
                        </Grid>
                        <Grid Grid.Row="3" Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="FeedbackPromotionSummaryText" Text="승격 결과를 읽기 전입니다." Foreground="#475569" />
                            <DataGrid x:Name="FeedbackPromotionGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      Margin="0,6,0,0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ExampleId" Binding="{Binding ExampleId}" Width="130" />
                                    <DataGridTextColumn Header="FeedbackId" Binding="{Binding FeedbackId}" Width="130" />
                                    <DataGridTextColumn Header="TaskId" Binding="{Binding TaskId}" Width="120" />
                                    <DataGridTextColumn Header="ReviewStatus" Binding="{Binding ReviewStatus}" Width="120" />
                                    <DataGridTextColumn Header="PromotionMode" Binding="{Binding PromotionMode}" Width="150" />
                                    <DataGridTextColumn Header="PromotedAt" Binding="{Binding PromotedAtText}" Width="130" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                        <Button Grid.Row="4" Content="승인 승격" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnPromoteFeedbackExample" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="HistoryTab" Header="History">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="HistorySummaryText" Text="감사 로그를 읽기 전입니다." Foreground="#475569" />
                        <DataGrid x:Name="HistoryGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Margin="0,8,0,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="90" />
                                <DataGridTextColumn Header="CreatedAt" Binding="{Binding CreatedAtText}" Width="130" />
                                <DataGridTextColumn Header="EntryId" Binding="{Binding EntryId}" Width="150" />
                                <DataGridTextColumn Header="TaskId" Binding="{Binding TaskId}" Width="150" />
                                <DataGridTextColumn Header="Activity" Binding="{Binding ActivityType}" Width="120" />
                                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="130" />
                                <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="110" />
                                <DataGridTextColumn Header="RuleVersion" Binding="{Binding RuleVersion}" Width="120" />
                                <DataGridTextColumn Header="UserHash" Binding="{Binding UserHashPrefix}" Width="95" />
                                <DataGridTextColumn Header="ReqHash" Binding="{Binding RequestHashPrefix}" Width="95" />
                                <DataGridTextColumn Header="OutHash" Binding="{Binding OutputHashPrefix}" Width="95" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Grid.Row="2" Content="로그 새로고침" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnRefreshHistory" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="SettingsTab" Header="Settings">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="SettingsSummaryText" Text="설정을 읽기 전입니다." Foreground="#475569" />
                        <DataGrid x:Name="SettingsGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Margin="0,8,0,0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="120" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="190" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="110" />
                                <DataGridTextColumn Header="Meaning" Binding="{Binding Meaning}" Width="260" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Grid.Row="2" Content="설정 새로고침" Width="110" HorizontalAlignment="Left" Margin="0,10,0,0" Click="OnRefreshSettings" />
                    </Grid>
                </TabItem>
            </TabControl>

            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                    <TextBlock Text="결과" FontSize="16" FontWeight="Bold" />
                    <TextBlock x:Name="FindingSummaryText" Text="Ready" Foreground="#475569" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                </DockPanel>
                <ListBox x:Name="FindingList" Grid.Row="1" BorderBrush="#CBD5E1" BorderThickness="1" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Background}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="2">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Foreground="{Binding Foreground}">
                                        <Run Text="{Binding Severity}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding Code}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Foreground="#64748B" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <GridSplitter x:Name="WorkspaceSafetySplitter" Grid.Row="1" Grid.Column="2"
                      Width="6"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                      Background="#E2E8F0" />

        <Border Grid.Row="1" Grid.Column="3" Background="#FAFAFA" Padding="14" BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
            <StackPanel>
                <TextBlock Text="Safety Check" FontSize="16" FontWeight="Bold" />
                <TextBlock Text="초기 MVP는 모델 없이도 룰 엔진이 동작합니다." TextWrapping="Wrap" Margin="0,8,0,16" />
                <TextBlock Text="Status" FontWeight="Bold" />
                <TextBlock x:Name="SafetyStatusText" Text="Ready" Margin="0,6,0,16" />
                <TextBlock Text="Hidden Risk" FontWeight="Bold" />
