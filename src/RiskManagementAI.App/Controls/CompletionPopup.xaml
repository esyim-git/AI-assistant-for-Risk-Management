<UserControl x:Class="RiskManagementAI.App.Controls.CompletionPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <Popup x:Name="RootPopup"
           Placement="Bottom"
           StaysOpen="False"
           AllowsTransparency="True"
           PopupAnimation="Fade">
        <Border Background="White"
                BorderBrush="#94A3B8"
                BorderThickness="1"
                CornerRadius="4"
                Padding="4"
                MinWidth="380"
                MaxWidth="640"
                MaxHeight="320">
            <ListBox x:Name="CompletionList"
                     MinHeight="60"
                     MaxHeight="300"
                     KeyboardNavigation.TabNavigation="Cycle"
                     MouseDoubleClick="OnCompletionListMouseDoubleClick"
                     PreviewKeyDown="OnCompletionListPreviewKeyDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2" MinWidth="340">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Text="검토용 초안" Foreground="#92400E" FontSize="11" Margin="8,0,0,0" />
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,3,0,0">
                                <TextBlock Text="Source:" Foreground="#64748B" FontSize="11" />
                                <TextBlock Text="{Binding Source}" Foreground="#475569" FontSize="11" Margin="3,0,8,0" />
                                <TextBlock Text="Kind:" Foreground="#64748B" FontSize="11" />
                                <TextBlock Text="{Binding Kind}" Foreground="#475569" FontSize="11" Margin="3,0,8,0" />
                                <TextBlock Text="RequiresReview:" Foreground="#64748B" FontSize="11" />
                                <TextBlock Text="{Binding RequiresReview}" Foreground="#475569" FontSize="11" Margin="3,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Popup>
</UserControl>
